{
  "table": "RT_LOAN_DBF",
  "description": "Return Swap trade-level loan and position data table. Stores per-trade values including deal prices, start/roll/maturity dates, rate margins, haircuts, and delivery configuration for each leg. Used by all Return Swap product types (BRS, equity TRS, index TRS) and Commodity Return Swaps. Joined to RT_INSGN_DBF to resolve the generator template: if M_GEN_NUM > 0, join RT_LOAN_DBF[M_GEN_NUM] to RT_INSGN_DBF[M_GEN_NUM] (customized generator); if M_GEN_NUM < 0, join RT_LOAN_DBF[M_GEN_INSNUM] to RT_INSGN_DBF[M_GEN_NUM] (default generator). Leg delivery type resolved via M_GENCURTP / M_GENCURTP2: if 0=Currency, join M_GENCURID / M_GENCURID2 to CMC_DLV_DBF[M_REFERENCE] (cash delivery); if 9=Commodity, join M_GENCURID / M_GENCURID2 to CM_PHYS_DBF[M_REFERENCE] (physical delivery).",
  "source": "MX_FIELDS_DOC_V0.xlsx + COMMODITIES_DB_TABLES_MUREX.xlsx — internal Qaracter documentation, June 2026",
  "leg_suffix_convention": {
    "0": "Security / performance leg (or physical/commodity leg)",
    "1": "Interest / financing leg (or cash/currency leg)"
  },
  "fields": [
    { "field_label": "Generator / Template Number", "subtype": "General", "db_column": "M_GEN_NUM", "db_column_uncertain": false, "values": null, "remark": "Join key to RT_INSGN_DBF. If M_GEN_NUM > 0: customized generator (RT_LOAN_DBF[M_GEN_NUM] -> RT_INSGN_DBF[M_GEN_NUM]). If M_GEN_NUM < 0: default generator (RT_LOAN_DBF[M_GEN_INSNUM] -> RT_INSGN_DBF[M_GEN_NUM])." },
    { "field_label": "Delivery Mode", "subtype": "General", "db_column": "M_EXR_MODE", "db_column_uncertain": false, "values": { "0": "Cash settled", "1": "Physical delivery / Financial delivery" }, "remark": null },
    { "field_label": "Generator Type Leg 0", "subtype": "General", "db_column": "M_GENCURTP", "db_column_uncertain": false, "values": { "0": "Currency", "9": "Commodity" }, "remark": "Determines the join target for M_GENCURID: if 0 -> CMC_DLV_DBF[M_REFERENCE] (cash delivery); if 9 -> CM_PHYS_DBF[M_REFERENCE] (physical delivery)." },
    { "field_label": "Generator Type Leg 1", "subtype": "General", "db_column": "M_GENCURTP2", "db_column_uncertain": false, "values": { "0": "Currency", "9": "Commodity" }, "remark": "Determines the join target for M_GENCURID2: if 0 -> CMC_DLV_DBF[M_REFERENCE] (cash delivery); if 9 -> CM_PHYS_DBF[M_REFERENCE] (physical delivery)." },
    { "field_label": "Deal Price Leg 1", "subtype": "Security leg", "db_column": "M_DEALPRIC0", "db_column_uncertain": false, "values": null, "remark": null },
    { "field_label": "Deal Price Leg 2", "subtype": "Interest leg", "db_column": "M_DEALPRIC1", "db_column_uncertain": false, "values": null, "remark": null },
    { "field_label": "Deal Price Type Leg 1", "subtype": "Security leg", "db_column": "M_DEALPRIC_T0", "db_column_uncertain": false, "values": { "1": "Clean price", "2": "Dirty price", "3": "Yield price" }, "remark": null },
    { "field_label": "Deal Price Type Leg 2", "subtype": "Interest leg", "db_column": "M_DEALPRIC_T1", "db_column_uncertain": false, "values": { "1": "Clean price", "2": "Dirty price", "3": "Yield price" }, "remark": null },
    { "field_label": "Start Date Leg 1", "subtype": "Security leg", "db_column": "M_START_DAT0", "db_column_uncertain": false, "values": null, "remark": null },
    { "field_label": "Start Date Leg 2", "subtype": "Interest leg", "db_column": "M_START_DAT1", "db_column_uncertain": false, "values": null, "remark": null },
    { "field_label": "Roll Date Leg 1", "subtype": "Security leg", "db_column": "M_ROLL_DATE0", "db_column_uncertain": false, "values": null, "remark": null },
    { "field_label": "Roll Date Leg 2", "subtype": "Interest leg", "db_column": "M_ROLL_DATE1", "db_column_uncertain": false, "values": null, "remark": null },
    { "field_label": "Physical Delivery Date / Maturity Date Leg 1", "subtype": "Security leg", "db_column": "M_MATURITY0", "db_column_uncertain": false, "values": null, "remark": "For commodity trades: the physical delivery date. For BRS and other return swaps: the maturity date of leg 1." },
    { "field_label": "Maturity Date Leg 2", "subtype": "Interest leg", "db_column": "M_MATURITY1", "db_column_uncertain": false, "values": null, "remark": null },
    { "field_label": "Rate Margin Leg 1", "subtype": "Security leg", "db_column": "M_RATE_MARG0", "db_column_uncertain": false, "values": null, "remark": null },
    { "field_label": "Rate Margin / Price Leg 2", "subtype": "Interest leg", "db_column": "M_RATE_MARG1", "db_column_uncertain": false, "values": null, "remark": "For commodity trades: used to compute Total Amount = M_RATE_MARG1 * CMT_DLV_DBF.M_TOT_QTY." },
    { "field_label": "Currency Leg 1", "subtype": "Security leg", "db_column": "M_CAP_CUR1", "db_column_uncertain": false, "values": null, "remark": "For commodity trades: the settlement currency. Also used as Total Amount Currency." },
    { "field_label": "Haircut % Leg 1", "subtype": "Security leg", "db_column": "M_HAIRCUT0", "db_column_uncertain": false, "values": null, "remark": null },
    { "field_label": "Haircut % Leg 2", "subtype": "Interest leg", "db_column": "M_HAIRCUT1", "db_column_uncertain": false, "values": null, "remark": null },
    { "field_label": "Haircut Formula Leg 1", "subtype": "Security leg", "db_column": "M_HAIRFRM0", "db_column_uncertain": false, "values": { "0": "1/(1 +/- x)", "1": "1 +/- x" }, "remark": null },
    { "field_label": "Haircut Formula Leg 2", "subtype": "Interest leg", "db_column": "M_HAIRFRM1", "db_column_uncertain": false, "values": { "0": "1/(1 +/- x)", "1": "1 +/- x" }, "remark": null },
    { "field_label": "Maturity Label", "subtype": "General", "db_column": "M_MAT_LAB", "db_column_uncertain": false, "values": null, "remark": null },
    { "field_label": "Additional Flows", "subtype": "General", "db_column": "M_ADD_FLOWS", "db_column_uncertain": false, "values": { "1": "Yes", "0": "No" }, "remark": null }
  ],
  "fields_missing_db_mapping": []
}
